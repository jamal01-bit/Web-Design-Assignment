body {
    font-family: georgian ;
    background-color: #00ff33 ;
    color: black ;
}

nav {
    text-align: center ; 
    background-color: #00ff33 ;
    border-bottom: 2px solid black ;
    position: sticky ;
    top: 0 ;
    width: 100% ;
    padding: 10px ;
}

nav ul {
    list-style-type: none ;
}

nav ul li {
    display: inline-block ;
    margin: 5px ;
}

nav ul li a {
    color: black ;
    text-decoration: none ;
    font-weight: bold ;
}

ul li a:hover {
    text-decoration: underline ;
}

ul li a.active {
    border: 1px solid black ;
    background-color: yellow ;
    padding: 5px 10px ;
}

section {
    margin-bottom: 5px ;
}

h4 {
    font-size: 18px ;
}

img {
    width: 600px ;
    height: 400px ;
    display: center ;
    margin: 5px ;
}

fieldset {
    border: none ;
    padding: 10px 0 ;
    margin: 20px 0 ;
}

label {
    display: block ;
    margin-top: 10px ;
    font-weight: bold ;
}

.inline-label {
    display: inline ;
    font-weight: normal ;
    margin-top: 0 ;
}

input, textarea {
    width: 100% ;
    padding: 8px ;
    margin-top: 5px ;
    border: 1px solid black ;
}

input[type="radio"], input[type="checkbox"] {
    width: auto ;
}

